{
  "compilerOptions": {
    "target": "ES2022", // Atualizado para uma versão mais moderna do Node
    "module": "NodeNext", // <--- A MÁGICA ESTÁ AQUI: Diz para usar o ESM do Node
    "moduleResolution": "NodeNext", // <--- Ensina o TS a entender os imports com .js no final
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
